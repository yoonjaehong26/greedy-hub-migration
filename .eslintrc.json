{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "plugins": ["import"],
  "settings": {
    "import/resolver": {
      "typescript": {
        "project": "./tsconfig.json"
      }
    }
  },
  "rules": {
    "import/no-restricted-paths": ["error", {
      "zones": [
        {
          "target": "./src/shared",
          "from": "./src/features",
          "except": ["./src/shared/reader"],
          "message": "Ž†ąžĚīžĖī žúĄŽįė: sharedŽäĒ featuresŽ•ľ importŪē† žąė žóÜžäĶŽčąŽč§."
        },
        {
          "target": "./src/shared/core",
          "from": "./src/shared/components",
          "message": "Ž†ąžĚīžĖī žúĄŽįė: coreŽäĒ componentsŽ•ľ importŪē† žąė žóÜžäĶŽčąŽč§."
        },
        {
          "target": "./src/shared/lib",
          "from": "./src/shared/components",
          "message": "Ž†ąžĚīžĖī žúĄŽįė: libžĚÄ componentsŽ•ľ importŪē† žąė žóÜžäĶŽčąŽč§."
        }
      ]
    }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/no-unused-vars": ["warn", { "varsIgnorePattern": "^_", "argsIgnorePattern": "^_" }]
  }
}
